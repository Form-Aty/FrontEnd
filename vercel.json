{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://168.107.12.171.nip.io/api/:path*"
    },
    {
      "source": "/v3/api-docs/:path*",
      "destination": "https://168.107.12.171.nip.io/v3/api-docs/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
